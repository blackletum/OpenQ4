{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure OpenQ4 (Meson Debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\meson-task.ps1",
        "setup"
      ],
      "problemMatcher": []
    },
    {
      "label": "Compile OpenQ4 (Meson Debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\meson-task.ps1",
        "compile"
      ],
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "Stage OpenQ4 Install Tree (Meson Debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\meson-task.ps1",
        "install"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build OpenQ4 (Meson Debug)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Configure OpenQ4 (Meson Debug)",
        "Compile OpenQ4 (Meson Debug)",
        "Stage OpenQ4 Install Tree (Meson Debug)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Bake Light Grids (All MP)",
      "type": "shell",
      "command": "${workspaceFolder}\\.install\\OpenQ4-client_x64.exe",
      "args": [
        "+set",
        "logFile",
        "2",
        "+set",
        "logFileName",
        "logs/openq4_lightgrids.log",
        "+set",
        "developer",
        "1",
        "+set",
        "fs_basepath",
        "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Quake 4",
        "+set",
        "fs_savepath",
        "${workspaceFolder}\\.home",
        "+set",
        "fs_devpath",
        "${workspaceFolder}\\.install",
        "+set",
        "fs_game",
        "baseoq4",
        "+set",
        "net_serverDedicated",
        "0",
        "+bakeLightGrids",
        "all-mp",
        "-quit"
      ],
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build OpenQ4 (Meson Debug)"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\.install"
      },
      "problemMatcher": []
    }
  ]
}
